<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Shop</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css" />
</head>
<body>
    <header class="site-header">
        <div class="container">
            <a class="logo" href="/">MyShop</a>
            <form id="search-form" action="/search" method="get" class="search-form">
                <input name="q" id="q" placeholder="Tìm kiếm sản phẩm...">
                <button type="submit">Tìm</button>
            </form>
            <div id="user-area">
                <form id="login-form" class="login-form">
                    <input name="email" placeholder="email" required>
                    <input name="password" type="password" placeholder="password" required>
                    <button type="submit">Đăng nhập</button>
                </form>
                <div id="account-info" style="display:none">
                    <span id="account-name"></span>
                    <button id="logout">Logout</button>
                </div>
            </div>
        </div>
    </header>

<main class="container">
    <section id="register-section">
        <h2>Đăng ký</h2>
        <form id="register-form" class="register-form">
            <input name="name" placeholder="Họ và tên" required>
            <input name="email" placeholder="Email" required>
            <input name="password" type="password" placeholder="Mật khẩu" required>
            <button type="submit">Đăng ký</button>
        </form>
        <div id="register-msg" style="margin-top:8px;color:#c00"></div>
    </section>

    <section>
        <h2>Khuyến mãi</h2>
        <div class="grid">
            <% promotions.forEach(function(p){ %>
                <a class="card" href="/product/<%= p._id %>">
                    <img src="<%= p.images && p.images[0] ? p.images[0] : '/images/product-a.svg' %>" alt="<%= p.name %>">
                    <div class="card-body">
                        <h3><%= p.name %></h3>
                        <div class="price"><%= p.price %> VND <% if (p.isOnSale) { %> - <span class="discount">-<%= p.discount %>%</span><% } %></div>
                    </div>
                </a>
            <% }) %>
        </div>
    </section>

    <section>
        <h2>Mới nhất</h2>
        <div class="grid">
            <% newest.forEach(function(p){ %>
                <a class="card" href="/product/<%= p._id %>">
                    <img src="<%= p.images && p.images[0] ? p.images[0] : '/images/product-a.svg' %>" alt="<%= p.name %>">
                    <div class="card-body">
                        <h3><%= p.name %></h3>
                        <div class="price"><%= p.price %> VND</div>
                    </div>
                </a>
            <% }) %>
        </div>
    </section>

    <section>
        <h2>Bán chạy</h2>
        <div class="grid">
            <% bestsellers.forEach(function(p){ %>
                <a class="card" href="/product/<%= p._id %>">
                    <img src="<%= p.images && p.images[0] ? p.images[0] : '/images/product-a.svg' %>" alt="<%= p.name %>">
                    <div class="card-body">
                        <h3><%= p.name %></h3>
                        <div class="price"><%= p.price %> VND</div>
                    </div>
                </a>
            <% }) %>
        </div>
    </section>
</main>

    <footer class="site-footer">
        <div class="container">&copy; <%= new Date().getFullYear() %> MyShop</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js"></script>

    <script>
    document.addEventListener('DOMContentLoaded', function(){
        // Register form
        const registerForm = document.getElementById('register-form');
        const registerMsg = document.getElementById('register-msg');
        if (registerForm) {
            registerForm.addEventListener('submit', async function(e){
                e.preventDefault();
                registerMsg.style.color = '#333';
                registerMsg.textContent = 'Đang gửi...';
                const fd = new FormData(registerForm);
                const payload = { name: fd.get('name'), email: fd.get('email'), password: fd.get('password') };
                try {
                    const res = await fetch('/v1/api/register', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const data = await res.json();
                    if (data && data._id) {
                        registerMsg.style.color = 'green';
                        registerMsg.textContent = 'Đăng ký thành công. Vui lòng đăng nhập.';
                        registerForm.reset();
                    } else {
                        registerMsg.style.color = 'red';
                        registerMsg.textContent = 'Đăng ký không thành công. Vui lòng thử lại.';
                    }
                } catch (err) {
                    registerMsg.style.color = 'red';
                    registerMsg.textContent = 'Lỗi kết nối. Vui lòng thử lại.';
                }
            });
        }

        // Login form (header)
        const loginForm = document.getElementById('login-form');
        const accountInfo = document.getElementById('account-info');
        const accountName = document.getElementById('account-name');
        if (loginForm) {
            loginForm.addEventListener('submit', async function(e){
                e.preventDefault();
                const fd = new FormData(loginForm);
                const payload = { email: fd.get('email'), password: fd.get('password') };
                try {
                    const res = await fetch('/v1/api/login', {
                        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
                    });
                    const data = await res.json();
                    if (data && data.access_token) {
                        localStorage.setItem('access_token', data.access_token);
                        localStorage.setItem('user_name', data.user && data.user.name ? data.user.name : payload.email);
                        if (loginForm) loginForm.style.display = 'none';
                        if (accountInfo) { accountInfo.style.display = 'block'; accountName.textContent = localStorage.getItem('user_name'); }
                    } else {
                        alert(data.EM || 'Đăng nhập thất bại');
                    }
                } catch (err) {
                    alert('Lỗi đăng nhập');
                }
            });
        }

        // Always attach logout handler
        const logoutBtn = document.getElementById('logout');
        if (logoutBtn) logoutBtn.addEventListener('click', function(){
            localStorage.removeItem('access_token'); localStorage.removeItem('user_name');
            if (loginForm) loginForm.style.display = 'flex';
            if (accountInfo) accountInfo.style.display = 'none';
        });

        // Show account area if already logged
        if (localStorage.getItem('access_token')) {
            if (loginForm) loginForm.style.display = 'none';
            if (accountInfo) { accountInfo.style.display = 'block'; accountName.textContent = localStorage.getItem('user_name') || ''; }
        }
    });
    </script>
</body>
</html>